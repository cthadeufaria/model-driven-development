@startuml
skinparam usecase {
  BackgroundColor<<added>> #90EE90
  BackgroundColor<<removed>> #FFB6C1
}
skinparam class {
  BackgroundColor<<added>> #90EE90
  BackgroundColor<<removed>> #FFB6C1
}
skinparam component {
  BackgroundColor<<added>> #90EE90
  BackgroundColor<<removed>> #FFB6C1
}
skinparam state {
  BackgroundColor<<added>> #90EE90
  BackgroundColor<<removed>> #FFB6C1
}
skinparam rectangle {
  BackgroundColor<<added>> #90EE90
  BackgroundColor<<removed>> #FFB6C1
}
skinparam actor {
  BackgroundColor<<added>> #90EE90
  BackgroundColor<<removed>> #FFB6C1
}
skinparam participant {
  BackgroundColor<<added>> #90EE90
  BackgroundColor<<removed>> #FFB6C1
