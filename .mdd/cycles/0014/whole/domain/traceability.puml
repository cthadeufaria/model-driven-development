title MDD traceability — domain (current)

class SymbolSpan {
  + path : String
  + symbol : String
  + line_start : usize
  + line_end : usize
  + kind : String
}

class SourceLink {
  + model_id : String
  + path : String
  + symbol : Option<String>
}

class TraceabilityReport {
  + matched : bool
  + mode : ParityMode
  + base : String
  + forward_errors : Vec<ForwardError>
  + reverse_bucket_a : Vec<String>
  + reverse_bucket_b : Vec<ReverseViolation>
}

SourceLink "1" ..> "0..1" SymbolSpan : resolves to >
TraceabilityReport "1" o-- "*" SourceLink : verifies >

