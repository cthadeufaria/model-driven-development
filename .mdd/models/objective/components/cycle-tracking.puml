@startuml
' @id(CMP-CYCLE-ORCHESTRATOR)
' @id(CMP-CYCLE-STORE)
' @id(CMP-CORE-CYCLE-MODEL)
' @id(CMP-VIEWER-CYCLE-UI)
' @ref(USE-RUN-CYCLE)
' @ref(USE-CYCLE-DIFF-VIEW)
'
' Objective-side ownership boundaries for cycle tracking. The skill owns
' orchestration + cycle boundary; mdd-core owns parsing the store and
' @desc markers; mdd-viewer owns the tree/diff/description UI.
'
' @desc(CMP-CYCLE-ORCHESTRATOR, "The /mdd-cycle skill: selects the entry point, owns the cycle boundary, loops the sub-skills to parity, and pauses for clarification.")
' @desc(CMP-CYCLE-STORE, ".mdd/cycles/ on disk: per-cycle manifest + before/ + after/ snapshots + annotated .diff.puml artifacts.")
' @desc(CMP-CORE-CYCLE-MODEL, "mdd-core readers: CycleRegistry, the @desc extractor, and the DiffEngine that partitions before/after element sets.")
' @desc(CMP-VIEWER-CYCLE-UI, "mdd-viewer UI: directory/cycle tree rail, superposed diff view, and the MODEL CONTEXT description card.")
title Cycle tracking — ownership (objective)

actor "Developer" as Dev

component "/mdd-cycle\n(orchestration skill)" as Orch
package "existing workflow skills" {
  component "/mdd-generate" as Gen
  component "/mdd-map" as MapS
  component "/mdd-validate" as ValS
  component "/mdd-implement" as ImplS
  component "/mdd-review" as RevS
}

folder ".mdd/cycles/<n>/\nmanifest.yml, before/, after/,\n<diagram>.diff.puml" as Store
folder ".mdd/models/, .mdd/trace.yml" as Models

component "mdd-core\nCycleRegistry, DescIndex,\nDiffEngine" as Core
component "mdd-viewer\nTree rail, Diff view,\nDescription card" as Viewer
component "eframe / egui 0.30" as Egui

Dev --> Orch : /mdd-cycle [description?]
Orch --> Gen : entry (description given)
Orch --> MapS : entry (no description)
Orch --> ValS : gate
Orch --> ImplS : write code
Orch --> RevS : parity
Orch --> Store : open / snapshot before / close / snapshot after / write diff
Gen --> Models : objective + @desc
MapS --> Models : current + @desc

Dev --> Viewer : mdd view
Viewer --> Core : registry, cycles, descriptions, diffs
Core --> Store : read manifest + snapshots
Core --> Models : scan models + @desc
Viewer --> Egui : tree / diff / card widgets
Egui --> Dev : tree rail + superposed diff + description card

note bottom of Store
  Per-cycle history is durable: every cycle
  keeps its own folder, so any past cycle's
  diff can be reopened later (decision: keep
  per-cycle snapshots on disk).
end note

note bottom of Orch
  Owns the cycle boundary. No standalone
  /mdd-map or /mdd-generate auto-opens a
  cycle; only this skill does.
end note
@enduml
