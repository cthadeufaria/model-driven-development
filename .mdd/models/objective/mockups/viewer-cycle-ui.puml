@startsalt
' @id(MCK-VIEWER-CYCLE-UI)
' @ref(USE-BROWSE-TREE)
' @ref(USE-DIFF-DIAGRAM)
' @ui-viewport(desktop,1280,800)
' Layout-only slice reference (objective): deliberately NO @ui-route and no
' @ui-element. Under the two-part mockup convention the whole-window UIC-
' contract is owned by MCK-VIEWER-FULL (objective/mockups/viewer-full.puml),
' which carries the route + React render; this slice stays a layout
' reference so UIC- ids remain unique per side.
'
' @desc(MCK-VIEWER-CYCLE-UI, "Reference layout for the cycle-aware viewer: tree rail with directory/cycle toggle; Diff mode bound to the selected cycle and the rail-selected file, with an inner Diagram/List toggle, a green/red legend, the superposed diagram canvas, and the MODEL CONTEXT card.")
title mdd viewer — cycle-aware layout (objective)
{
  { mdd | /path/to/project }
  --
  {
    {
      "DIAGRAMS"
      [Directory] | [By cycle]
      {T
        + .mdd/models
        ++ current
        +++ domain
        ++++ <b>canvas-view.puml  (selected)
        +++ use-cases
        ++ objective
      }
    } |
    {
      { [Diagram] | [*Diff] }
      "CYCLE:  [*0002 closed] | [0001 closed]"
      "view:   [*Diagram] | [List]"
      --
      "canvas-view.puml — cycle 0002 (superposed)"
      {
        "shared element (neutral)"
        "<color:green>+ added by this cycle</color>"
        "<color:red>- removed by this cycle</color>"
      }
      .
      "[ superposed diff diagram canvas — pan/zoom ]"
      .
      "(List view here = added/removed/unchanged"
      " text buckets for canvas-view.puml only)"
    } |
    {
      "MODEL CONTEXT"
      --
      "file"
      { current/domain/canvas-view.puml }
      "kind"
      { domain }
      {^"DESCRIPTION"
        "DOM-CANVAS-VIEW"
        "Code struct CanvasView: base zoom/pan"
        "plus the center-fixed fisheye params."
      }
      "IDS"
      { DOM-CANVAS-VIEW }
      "TRACE"
      { SEQ-CANVAS-FISHEYE -> depends_on -> DOM-CANVAS-VIEW }
    }
  }
}
@endsalt
