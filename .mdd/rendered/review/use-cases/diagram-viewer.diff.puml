@startuml
skinparam usecase {
  BackgroundColor<<missing>> #90EE90
  BackgroundColor<<extra>> #FFB6C1
}
skinparam class {
  BackgroundColor<<missing>> #90EE90
  BackgroundColor<<extra>> #FFB6C1
}
skinparam component {
  BackgroundColor<<missing>> #90EE90
  BackgroundColor<<extra>> #FFB6C1
}
skinparam state {
  BackgroundColor<<missing>> #90EE90
  BackgroundColor<<extra>> #FFB6C1
}
skinparam rectangle {
  BackgroundColor<<missing>> #90EE90
  BackgroundColor<<extra>> #FFB6C1
}
skinparam actor {
  BackgroundColor<<missing>> #90EE90
  BackgroundColor<<extra>> #FFB6C1
}
skinparam participant {
  BackgroundColor<<missing>> #90EE90
  BackgroundColor<<extra>> #FFB6C1
